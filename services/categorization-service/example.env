# =============================================================================
# Categorization Service Configuration
# =============================================================================

# PostgreSQL connection (required)
# Format: postgresql+asyncpg://user:password@host:port/database
DATABASE_URL=postgresql+asyncpg://categorization_service:categorization_service_pass@localhost:5435/categorization

# RabbitMQ connection (required for event consumption/production)
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# JWT verification (must match user-service issuer)
JWT_SECRET=dev-secret-key-change-in-production
JWT_ALGORITHM=HS256

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Environment: development, staging, production
ENVIRONMENT=development

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
