# Transaction service (transactions, CSV import, planned transactions)
VITE_TRANSACTION_SERVICE_URL=http://localhost:8002/api/v1

# Budget service (budgets)
VITE_BUDGET_SERVICE_URL=http://localhost:8003/api/v1

# Goal service (savings goals)
VITE_GOAL_SERVICE_URL=http://localhost:8006/api/v1

# Banking service (PSD2 bank connect and sync)
VITE_BANKING_SERVICE_URL=http://localhost:8009/api/v1
