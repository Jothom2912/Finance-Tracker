# =============================================================================
# Saga Service Configuration
# =============================================================================

# PostgreSQL connection string (required in production)
# Format: postgresql+asyncpg://user:password@host:port/database
DATABASE_URL=postgresql+asyncpg://saga_service:saga_service_pass@localhost:5440/saga

# RabbitMQ connection string for saga commands and replies
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# Comma-separated CORS origins for the status API
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Environment: development, staging, production
ENVIRONMENT=development

# =============================================================================
# Saga Lifecycle
# =============================================================================

# Mark active sagas as timed_out when updated_at is older than this (seconds)
SAGA_TIMEOUT_SECONDS=300

# How often the timeout worker scans for stale sagas (seconds)
TIMEOUT_CHECK_INTERVAL_SECONDS=30
