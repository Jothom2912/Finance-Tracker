%% Finans Tracker - Target State Microservice Architecture
%% Last updated: 2026-03-18
%%
%% This diagram shows the target-state architecture after full monolith extraction.
%% The monolith is NOT shown - it will be decommissioned via strangler fig pattern.
%%
%% Color legend:
%%   Blue    = Currently deployed services
%%   Green   = Phase 1: Extract from monolith
%%   Orange  = Phase 2: Future services
%%   Purple  = Infrastructure (databases, message broker)
%%   Red     = Outbox pattern (workers + outbox tables)
%%   Yellow  = Search infrastructure (Elasticsearch)

graph TD
    %% ──────────────────────────────────────────────
    %% Clients
    %% ──────────────────────────────────────────────
    subgraph Clients
        FE["React Frontend - Vite<br/>Direct service routing<br/>No API Gateway"]
    end

    %% ──────────────────────────────────────────────
    %% External integrations
    %% ──────────────────────────────────────────────
    subgraph External
        TINK["Tink API<br/>PSD2 Bank Data"]
        LLM["LLM Provider<br/>Claude / Ollama"]
        OAUTH["OAuth Provider<br/>Google / MitID"]
    end

    %% ──────────────────────────────────────────────
    %% Currently deployed services
    %% ──────────────────────────────────────────────
    subgraph currentServices ["Currently Deployed Services"]
        subgraph userService ["User Service - port 8001"]
            US["UserService<br/>Registration, Login<br/>JWT Issuing - source of truth"]
            US_DB[("PostgreSQL<br/>Users, Credentials")]
            US_OB[["outbox_events"]]
        end

        subgraph transactionService ["Transaction Service - port 8002"]
            TS["TransactionService<br/>Transaction CRUD, CSV Import<br/>Planned Transactions<br/>Category CRUD owner"]
            TS_DB[("PostgreSQL<br/>Transactions<br/>Planned Transactions<br/>Categories")]
            TS_OB[["outbox_events"]]
        end
    end

    %% ──────────────────────────────────────────────
    %% Phase 1: Extract from monolith
    %% ──────────────────────────────────────────────
    subgraph phase1 ["Phase 1 - Extract from Monolith"]
        subgraph budgetService ["Budget Service - port 8003"]
            BS["BudgetService<br/>Budgets, MonthlyBudgets<br/>Expense aggregates via events<br/>Category local copy via events"]
            BS_DB[("PostgreSQL<br/>Budgets<br/>Categories - local copy<br/>Expense aggregates per category")]
            BS_OB[["outbox_events"]]
        end

        subgraph accountService ["Account Service - port 8004"]
            ACCS["AccountService<br/>Accounts, Account Groups<br/>Goals<br/>Minimal user data from events"]
            ACCS_DB[("PostgreSQL<br/>Accounts, Goals<br/>Users - cached from events")]
            ACCS_OB[["outbox_events"]]
        end

        subgraph analyticsService ["Analytics BFF - port 8005"]
            AS["AnalyticsService<br/>Dashboard aggregation<br/>GraphQL read gateway<br/>Hybrid: ES for aggregation + HTTP for lookups"]
            AS_ES[("Elasticsearch<br/>Denormalized read store<br/>Projected from all domain events")]
        end
    end

    %% ──────────────────────────────────────────────
    %% Phase 2: Future services
    %% ──────────────────────────────────────────────
    subgraph phase2 ["Phase 2 - Future"]
        subgraph aiService ["AI Categorization Service"]
            CAT["CategorizationService<br/>Rule - ML - LLM fallback<br/>Human-in-the-loop feedback"]
        end
    end

    %% ──────────────────────────────────────────────
    %% Outbox workers (one per service)
    %% ──────────────────────────────────────────────
    subgraph outboxWorkers ["Outbox Workers"]
        UOW["User Outbox Worker<br/>SELECT FOR UPDATE SKIP LOCKED"]
        TOW["Transaction Outbox Worker"]
        AOW["Account Outbox Worker"]
        BOW["Budget Outbox Worker"]
    end

    %% ──────────────────────────────────────────────
    %% Event backbone
    %% ──────────────────────────────────────────────
    subgraph eventBackbone ["Event Backbone"]
        RMQ["RabbitMQ<br/>Exchange: finans_tracker.events<br/>Topic routing"]
    end

    %% ──────────────────────────────────────────────
    %% Frontend → Services (direct routing, no gateway)
    %% ──────────────────────────────────────────────
    FE -->|"REST /users"| US
    FE -->|"REST /transactions<br/>/categories"| TS
    FE -->|"REST /budgets"| BS
    FE -->|"REST /accounts<br/>/goals"| ACCS
    FE -->|"GraphQL /analytics"| AS

    %% ──────────────────────────────────────────────
    %% External integrations
    %% ──────────────────────────────────────────────
    TINK -.->|"bank transactions"| TS
    LLM -.->|"categorization"| CAT
    OAUTH -.->|"auth tokens"| US

    %% ──────────────────────────────────────────────
    %% Services → Own databases
    %% ──────────────────────────────────────────────
    US --> US_DB
    TS --> TS_DB
    BS --> BS_DB
    ACCS --> ACCS_DB
    AS --> AS_ES

    %% ──────────────────────────────────────────────
    %% Transactional outbox (write in same DB transaction)
    %% ──────────────────────────────────────────────
    US -.->|"same txn"| US_OB
    TS -.->|"same txn"| TS_OB
    BS -.->|"same txn"| BS_OB
    ACCS -.->|"same txn"| ACCS_OB

    %% ──────────────────────────────────────────────
    %% Outbox workers: poll → publish
    %% ──────────────────────────────────────────────
    UOW -->|"poll"| US_OB
    UOW -->|"publish"| RMQ
    TOW -->|"poll"| TS_OB
    TOW -->|"publish"| RMQ
    BOW -->|"poll"| BS_OB
    BOW -->|"publish"| RMQ
    AOW -->|"poll"| ACCS_OB
    AOW -->|"publish"| RMQ

    %% ──────────────────────────────────────────────
    %% Sync HTTP lookups (minimal, only where needed)
    %% ──────────────────────────────────────────────
    AS -->|"HTTP: user details<br/>for dashboard display"| US

    %% ──────────────────────────────────────────────
    %% Event flows: RabbitMQ → consumers
    %% ──────────────────────────────────────────────
    RMQ -->|"user.created"| ACCS
    RMQ -->|"transaction.created/deleted"| BS
    RMQ -->|"category.created/updated/deleted"| BS
    RMQ -->|"all domain events"| AS
    RMQ -.->|"transaction.created<br/>Phase 2"| CAT

    %% ──────────────────────────────────────────────
    %% JWT auth flow
    %% ──────────────────────────────────────────────
    US -->|"Issues JWT"| FE

    %% ──────────────────────────────────────────────
    %% Styling
    %% ──────────────────────────────────────────────
    classDef current fill:#e1f5fe,stroke:#0288d1
    classDef phase1sty fill:#e8f5e9,stroke:#388e3c
    classDef phase2sty fill:#fff3e0,stroke:#f57c00,stroke-dasharray: 5 5
    classDef infra fill:#f3e5f5,stroke:#7b1fa2
    classDef outbox fill:#fce4ec,stroke:#c62828
    classDef search fill:#fff9c4,stroke:#f9a825

    class US,TS current
    class ACCS,BS,AS phase1sty
    class CAT phase2sty
    class RMQ,US_DB,TS_DB,ACCS_DB,BS_DB infra
    class US_OB,TS_OB,ACCS_OB,BS_OB,UOW,TOW,AOW,BOW outbox
    class AS_ES search
