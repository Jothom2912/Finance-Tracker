graph TD
    subgraph Clients
        FE["React Frontend\n(Vite)"]
    end

    subgraph External
        TINK["Tink API\nPSD2 Bank Data"]
        LLM["LLM Provider\nClaude / Ollama"]
        OAUTH["OAuth Provider\nGoogle / MitID"]
    end

    subgraph currentServices ["Currently Deployed Services"]
        subgraph monolith ["Monolith (port 8000)"]
            MON["FastAPI Monolith\nAccounts, Categories,\nBudgets, Goals,\nTransactions, Analytics,\nGraphQL Read Gateway"]
            MON_DB[("MySQL\nAccounts, Categories\nBudgets, Goals\nTransactions, Users (cache)")]
        end

        subgraph userService ["User Service (port 8001)"]
            US["UserService\nRegistration, Login\nJWT Issuing (source of truth)"]
            US_DB[("PostgreSQL\nUsers, Credentials")]
        end

        subgraph transactionService ["Transaction Service (port 8002)"]
            TS["TransactionService\nCRUD, CSV Import\nPlanned Transactions\nToken validation only"]
            TS_DB[("PostgreSQL\nTransactions\nPlanned Transactions")]
        end

        subgraph consumers ["Event Consumers"]
            USC["UserSyncConsumer\nSync user to MySQL\nQueue: monolith.user_sync"]
            ACC["AccountCreationConsumer\nCreate default account\nQueue: monolith.account_creation"]
        end
    end

    subgraph futureServices ["Future Services (not yet extracted)"]
        subgraph budgetService ["Budget Service"]
            BS["BudgetService"]
            BS_DB[("PostgreSQL")]
        end

        subgraph analyticsService ["Analytics Service"]
            AS["AnalyticsService\nGraphQL Gateway"]
            AS_DB[("Elasticsearch")]
        end

        subgraph aiService ["AI / Categorization Service"]
            CAT["CategorizationService\nRule → ML → LLM"]
        end

        subgraph apiGateway ["API Gateway"]
            GW["API Gateway\nRouting, Rate Limiting\nJWT Validation, CORS"]
        end
    end

    subgraph eventBackbone ["Event Backbone"]
        RMQ["RabbitMQ\nExchange: finans_tracker.events\nTopic routing"]
    end

    %% Client -> Services (current: direct, future: via gateway)
    FE -->|"REST /api/v1/*\n(accounts, budgets,\ncategories, goals)"| MON
    FE -->|"REST /api/v1/users/*\n(register, login)"| US
    FE -->|"REST /api/v1/transactions/*\n(future: via gateway)"| TS

    %% Services -> Own databases
    MON --> MON_DB
    US --> US_DB
    TS --> TS_DB

    %% Consumers -> MySQL
    USC -->|"INSERT User"| MON_DB
    ACC -->|"INSERT Account"| MON_DB

    %% JWT flow
    US -->|"Issues JWT\n(sub claim)"| FE
    FE -->|"Bearer token"| MON
    FE -->|"Bearer token"| TS

    %% Event publishing
    US -->|"user.created"| RMQ

    %% Event consuming (two independent queues, same routing key)
    RMQ -->|"user.created\n→ monolith.user_sync"| USC
    RMQ -->|"user.created\n→ monolith.account_creation"| ACC

    %% Transaction events (for future consumers)
    TS -->|"transaction.created\ntransaction.deleted"| RMQ

    %% Account creation saga
    ACC -->|"account.created /\naccount.creation_failed"| RMQ

    %% Future event flows
    RMQ -.->|"ALL events"| AS

    %% Styling
    classDef current fill:#e1f5fe,stroke:#0288d1
    classDef future fill:#fff3e0,stroke:#f57c00,stroke-dasharray: 5 5
    classDef infra fill:#f3e5f5,stroke:#7b1fa2

    class MON,US,TS,USC,ACC current
    class BS,AS,CAT,GW future
    class RMQ,MON_DB,US_DB,TS_DB infra
