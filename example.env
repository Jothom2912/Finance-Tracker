# =============================================================================
# Application Configuration
# =============================================================================

# Environment: development, staging, production
ENVIRONMENT=development

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# =============================================================================
# Security (required)
# =============================================================================

# JWT secret key for token signing (required)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=

# JWT token expiration time in minutes (default: 60)
ACCESS_TOKEN_EXPIRE_MINUTES=60

# =============================================================================
# CORS Configuration
# =============================================================================

# Allowed origins for CORS (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# =============================================================================
# Service-to-service URLs
# =============================================================================

# Inter-service communication via Docker DNS
USER_SERVICE_URL=http://user-service:8001
TRANSACTION_SERVICE_URL=http://transaction-service:8002
BUDGET_SERVICE_URL=http://budget-service:8003
ACCOUNT_SERVICE_URL=http://account-service:8003
CATEGORIZATION_SERVICE_URL=http://categorization-service:8005
GOAL_SERVICE_URL=http://goal-service:8006
GATEWAY_SERVICE_URL=http://gateway-service:8010
BANKING_SERVICE_URL=http://banking-service:8009

# Frontend URL for server-to-browser redirects (e.g. bank OAuth callback)
FRONTEND_URL=http://localhost:3000

# HTTP timeout for bulk imports (seconds)
TRANSACTION_SERVICE_TIMEOUT=10

# =============================================================================
# Elasticsearch Configuration (optional — CQRS read store)
# =============================================================================

# Elasticsearch host URL
ELASTICSEARCH_HOST=http://localhost:9200

# Whether to sync data to Elasticsearch
SYNC_TO_ELASTICSEARCH=false

# =============================================================================
# Neo4j Configuration (optional — graph queries)
# =============================================================================

# Neo4j connection URI
NEO4J_URI=bolt://localhost:7687

# Neo4j credentials
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password-here

# Whether to use Neo4j for GraphQL queries
USE_NEO4J=false

# =============================================================================
# Enable Banking (Open Banking / PSD2)
# =============================================================================

# Application ID from Enable Banking Control Panel (required for bank sync)
# Register at: https://enablebanking.com/sign-in/
ENABLE_BANKING_APP_ID=

# Path to the PEM private key file (generated during app registration)
ENABLE_BANKING_KEY_PATH=./enablebanking-sandbox.pem

# URL where the bank redirects after user authorization
ENABLE_BANKING_REDIRECT_URI=http://localhost:8009/api/v1/bank/callback

# Environment: sandbox or production
ENABLE_BANKING_ENVIRONMENT=sandbox

# --- Docker Compose: aktiv Enable Banking-app (ACTIVE_ prefix avoids collision
# --- with the legacy ENABLE_BANKING_* values above; compose auto-loads .env).
# --- Unset → compose falls back to the dev sandbox app. Set both to run
# --- against production. Remember the redirect URI
# --- (http://localhost:8009/api/v1/bank/callback) must be registered on the
# --- app in the Enable Banking Control Panel. ---
# App id used by docker-compose.yml (defaults to the dev sandbox id)
#ENABLE_BANKING_ACTIVE_APP_ID=
# Host path to the matching PEM key mounted into containers.
# Keep the key OUTSIDE the repo, e.g. ~/Documents/enablebanking-privat.pem
#ENABLE_BANKING_ACTIVE_PEM_PATH=./enablebanking-sandbox.pem
# Production apps reject http/localhost redirect URLs. Register an https URL
# (e.g. https://example.com/callback) on the app and set it here; after bank
# auth, rewrite the browser URL to http://localhost:8009/api/v1/bank/callback
# keeping the ?code=...&state=... query string.
#ENABLE_BANKING_ACTIVE_REDIRECT_URI=
